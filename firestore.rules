rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Pages ──────────────────────────────────────────────────────────────
    // Public read (full document for simplicity — blocks are not sensitive)
    // Authenticated write
    match /pages/{slug} {
      allow read: if true;
      allow write: if request.auth != null;

      // Version subcollection: same rules
      match /versions/{versionId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // ─── Posts ──────────────────────────────────────────────────────────────
    match /posts/{slug} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Authors ────────────────────────────────────────────────────────────
    match /authors/{authorId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Submissions ────────────────────────────────────────────────────────
    // Anyone can create a submission (contact, demo request, etc.)
    // Only authenticated users can read
    match /submissions/{submissionId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ─── Newsletter ─────────────────────────────────────────────────────────
    // Anyone can subscribe
    // Only authenticated users can read the list
    match /newsletter/{email} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
